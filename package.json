{
  "name": "lumen-image-ranker",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:hosted": "node --import tsx --test tests/*.test.ts",
    "db:schema": "node --env-file=.env.local --import tsx scripts/apply-schema.ts",
    "db:verify": "node --env-file=.env.local --import tsx scripts/verify-schema.ts",
    "db:worker-role": "node --env-file=.env.local --import tsx scripts/provision-worker-role.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "1.1.0",
    "@vercel/blob": "2.6.1",
    "@vercel/queue": "0.4.0",
    "@vercel/sandbox": "2.7.1",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "tsx": "^4.23.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "overrides": {
    "postcss": "8.5.20"
  }
}
