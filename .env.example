# Optional: stage the runtime outside macOS TCC-protected folders.
# IMAGE_RANKER_ROOT=~/Library/Application Support/Lumen/runtime
IMAGE_RANKER_DATA=./data
IMAGE_RANKER_HOST=127.0.0.1
IMAGE_RANKER_PORT=8787
IMAGE_RANKER_REMOTE_PORT=8788
IMAGE_RANKER_REMOTE_TOKEN_FILE=./data/remote-token
IMAGE_RANKER_ALLOWED_ORIGIN=https://lumen-ranker.vercel.app
IMAGE_RANKER_TRAIN_MINIMUM=20
IMAGE_RANKER_TRAIN_BATCH=50
IMAGE_RANKER_UNRANKED_THRESHOLD=20
IMAGE_RANKER_CRAWL_LIMIT=60
IMAGE_RANKER_TRAIN_EPOCHS=300
IMAGE_RANKER_JOBS_INTERVAL=900
