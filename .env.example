# Local Python runtime (optional when using the hosted app only).
# IMAGE_RANKER_ROOT=~/Library/Application Support/Lumen/runtime
IMAGE_RANKER_DATA=./data
IMAGE_RANKER_HOST=127.0.0.1
IMAGE_RANKER_PORT=8787
IMAGE_RANKER_REMOTE_PORT=8788
IMAGE_RANKER_REMOTE_TOKEN_FILE=./data/remote-token
IMAGE_RANKER_ALLOWED_ORIGIN=https://lumen-ranker.vercel.app
IMAGE_RANKER_TRAIN_MINIMUM=20
IMAGE_RANKER_TRAIN_BATCH=50
IMAGE_RANKER_UNRANKED_THRESHOLD=20
IMAGE_RANKER_CRAWL_LIMIT=60
IMAGE_RANKER_TRAIN_EPOCHS=300
IMAGE_RANKER_JOBS_INTERVAL=900

# Hosted Auth.js session. Generate with: npx auth secret
AUTH_SECRET=
# Vercel supplies a trusted deployment host; set explicitly for local `next start`.
AUTH_TRUST_HOST=true

# Google Cloud OAuth web client. Callback: /api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# First deploy only: exact verified address allowed while the sub list is empty.
AUTH_BOOTSTRAP_EMAIL=

# Permanent owner identity: comma-separated immutable Google subject identifiers.
# After bootstrap, copy `user.id` from /api/auth/session here, then remove the
# bootstrap email. Once this list is non-empty, the email path is disabled.
AUTH_ALLOWED_GOOGLE_SUBS=

# Hosted private data services.
DATABASE_URL=
DATABASE_URL_UNPOOLED=
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=

# Direct, unpooled Neon URL for the least-privilege `lumen_worker` role.
# Production only; create it with `npm run db:worker-role` after applying schema.
LUMEN_WORKER_DATABASE_URL=

# Hosted automation. Scope every value to Production only.
CRON_SECRET=
LUMEN_SANDBOX_SNAPSHOT_ID=
